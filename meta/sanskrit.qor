(upasarga anu "after, along" "anu+√gam = anugacchati = follows") <0.99, 0.99>
(upasarga ava "down" "ava+√gam = avagacchati = understands") <0.99, 0.99>
(upasarga nis "out, without" "nis+√gam = nirgacchati = goes out") <0.99, 0.99>
