(upasarga dus "bad, difficult" "dus+√kṛ = duṣkaroti = does badly") <0.99, 0.99>
(upasarga su "good, well" "su+√kṛ = sukṛta = well-done") <0.99, 0.99>
(upasarga vi "apart, special" "vi+√jñā = vijānāti = discerns") <0.99, 0.99>
(upasarga ā "toward, until" "ā+√gam = āgacchati = comes") <0.99, 0.99>
(upasarga abhi "toward, over" "abhi+√dhā = abhidhatte = names") <0.99, 0.99>
(upasarga adhi "over, upon" "adhi+√gam = adhigacchati = attains") <0.99, 0.99>
(upasarga upa "near, toward" "upa+√gam = upagacchati = approaches") <0.99, 0.99>
(upasarga pari "around" "pari+√gam = parigacchati = goes around") <0.99, 0.99>
(upasarga prati "back, against, each" "prati+√gam = pratigacchati = returns") <0.99, 0.99>
(upasarga ati "beyond, over" "ati+√gam = atigacchati = surpasses") <0.99, 0.99>
(upasarga ud "up, out" "ud+√gam = udgacchati = rises") <0.99, 0.99>
(upasarga ut "up" "ut+√sthā = uttiṣṭhati = stands up") <0.99, 0.99>


