(dhātu i 2 parasmai "to go") <0.99, 0.99>
(dhātu nī 1 parasmai "to lead") <0.99, 0.99>
(dhātu pac 1 parasmai "to cook") <0.99, 0.99>
(dhātu likh 6 parasmai "to write") <0.99, 0.99>
(dhātu khād 1 parasmai "to eat, to chew") <0.99, 0.99>
(dhātu pā 1 parasmai "to drink") <0.99, 0.99>
(dhātu jñā 9 parasmai "to know, to understand") <0.99, 0.99>
(dhātu man 4 ātmane "to think") <0.99, 0.99>
(dhātu labh 1 ātmane "to obtain") <0.99, 0.99>
(dhātu vṛt 1 ātmane "to exist, to happen") <0.99, 0.99>
(dhātu yuj 7 ubhaya "to join, to yoke (→ yoga)") <0.99, 0.99>
(dhātu budh 1 ubhaya "to know, to wake (→ buddha)") <0.99, 0.99>

;; Voice categories
(voice parasmaipada "active — action for another") <0.99, 0.99>
(voice ātmanepada "middle — action for oneself") <0.99, 0.99>
(voice ubhayapada "both — can take either voice") <0.99, 0.99>

;; Example: full conjugation of √bhū (to be) in present tense
;; bhū + a (gaṇa 1 vikaraṇa) + guṇa = bhav + a = bhava-
(conjugation bhū laṭ prathama sg bhavati "he/she/it is") <0.99, 0.99>
(conjugation bhū laṭ prathama du bhavataḥ "they two are") <0.99, 0.99>
(conjugation bhū laṭ prathama pl bhavanti "they are") <0.99, 0.99>
(conjugation bhū laṭ madhyama sg bhavasi "you are") <0.99, 0.99>
(conjugation bhū laṭ madhyama du bhavathaḥ "you two are") <0.99, 0.99>
(conjugation bhū laṭ madhyama pl bhavatha "you all are") <0.99, 0.99>
(conjugation bhū laṭ uttama sg bhavāmi "I am") <0.99, 0.99>
(conjugation bhū laṭ uttama du bhavāvaḥ "we two are") <0.99, 0.99>
(conjugation bhū laṭ uttama pl bhavāmaḥ "we are") <0.99, 0.99>


;; ─── 7. VOWEL STRENGTHENING (Guṇa & Vṛddhi) ──────────────────────
;; Core transformation rules used throughout grammar

;; Guṇa (first level strengthening)
(rule guna-i (vowel i) → (guṇa e)) <0.99, 0.99>
(rule guna-u (vowel u) → (guṇa o)) <0.99, 0.99>
(rule guna-ri (vowel ṛ) → (guṇa ar)) <0.99, 0.99>
(rule guna-li (vowel ḷ) → (guṇa al)) <0.99, 0.99>
(rule guna-a (vowel a) → (guṇa a)) <0.99, 0.99>

;; Vṛddhi (second level strengthening)
(rule vrddhi-a (vowel a) → (vṛddhi ā)) <0.99, 0.99>
(rule vrddhi-i (vowel i) → (vṛddhi ai)) <0.99, 0.99>
(rule vrddhi-u (vowel u) → (vṛddhi au)) <0.99, 0.99>
(rule vrddhi-ri (vowel ṛ) → (vṛddhi ār)) <0.99, 0.99>


;; ─── 8. COMPOUND WORDS (Samāsa) ────────────────────────────────────

;; Types of compounds — rules for how words merge
(samāsa avyayībhāva "indeclinable compound: first member is prefix/indeclinable"
  "upakṛṣṇam = near Kṛṣṇa (upa + kṛṣṇa)") <0.99, 0.99>

(samāsa tatpuruṣa "determinative: first qualifies second, second is head"
  "rāja-puruṣaḥ = king's man (genitive tatpuruṣa)"
  "subtypes by case: dvitīyā through saptamī") <0.99, 0.99>

(samāsa karmadhāraya "descriptive: apposition, adjective+noun"
  "nīla-utpalam = blue lotus (adjective + noun)"
  "subtype of tatpuruṣa where both refer to same entity") <0.99, 0.99>

(samāsa dvigu "numeral compound: number + noun"
  "tri-lokī = three worlds (tri + loka)"
  "subtype of tatpuruṣa with numeral as first member") <0.99, 0.99>

(samāsa dvandva "copulative: A and B"
  "rāma-lakṣmaṇau = Rāma and Lakṣmaṇa"
  "both members equal, result takes dual/plural") <0.99, 0.99>

(samāsa bahuvrīhi "possessive/exocentric: compound describes external referent"
  "bahu-vrīhiḥ = [one who has] much rice (bahu+vrīhi)"
  "meaning is OUTSIDE the compound itself") <0.99, 0.99>

;; Compound resolution rules
(rule resolve-tatpurusha
  (compound $c tatpuruṣa $w1 $w2 $case)
  →
  (meaning $c "$w2 related-by-$case to $w1") <0.90, 0.90>
)

(rule resolve-bahuvrihi
  (compound $c bahuvrīhi $w1 $w2)
  →
  (meaning $c "one whose $w2 is $w1") <0.90, 0.90>
)

(rule resolve-dvandva
  (compound $c dvandva $w1 $w2)
  →
  (meaning $c "$w1 and $w2") <0.90, 0.90>
)


;; ─── 9. SENTENCE STRUCTURE (Vākya) ─────────────────────────────────

;; Sanskrit is FREE WORD ORDER — meaning comes from case endings, not position
(rule sanskrit-word-order
  (word $w1 $case1 $meaning1)
  (word $w2 $case2 $meaning2)
  (word $verb $lakāra $dhātu)
  →
  ;; Agent = prathamā, Object = dvitīyā, Instrument = tṛtīyā
  ;; word order does NOT matter, cases determine roles
  (sentence-role $w1 $case1)
  (sentence-role $w2 $case2)
  (sentence-action $verb $dhātu) <0.99, 0.99>
)

;; Kāraka (semantic roles) — THE key to understanding Sanskrit sentences
(rule identify-agent
  (word $w prathamā $meaning)
  (verb $v active)
  →
  (agent $w $meaning) <0.99, 0.99>
)

(rule identify-object
  (word $w dvitīyā $meaning)
  →
  (object $w $meaning) <0.99, 0.99>
)

(rule identify-instrument
  (word $w tṛtīyā $meaning)
  →
  (instrument $w $meaning) <0.99, 0.99>
)

(rule identify-recipient
  (word $w caturthī $meaning)
  →
  (recipient $w $meaning) <0.99, 0.99>
)

(rule identify-source
  (word $w pañcamī $meaning)
  →
  (source $w $meaning) <0.99, 0.99>
)

(rule identify-possessor
  (word $w ṣaṣṭhī $meaning)
  →
  (possessor $w $meaning) <0.99, 0.99>
)

(rule identify-location
  (word $w saptamī $meaning)
  →
  (location $w $meaning) <0.99, 0.99>
)


