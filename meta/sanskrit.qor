;; ─── 12. PREFIX SYSTEM (Upasarga) ───────────────────────────────────
;; 22 prefixes that modify verb/noun meaning

(upasarga pra "forward, forth, very" "pra+√bhū = prabhavati = arises") <0.99, 0.99>
(upasarga parā "away, back" "parā+√ji = parājayate = is defeated") <0.99, 0.99>
