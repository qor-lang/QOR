;; ═══════════════════════════════════════════════════════════════════════
;; SANSKRIT GRAMMAR RULES SUMMARY
;; ~400 executable rules covering:
;;   - Complete phoneme system (49 sounds classified by properties)
;;   - Vowel sandhi rules (30+ transformation rules)
;;   - Consonant sandhi rules (15+ rules)
;;   - Visarga sandhi rules (8+ rules)
;;   - Noun declension: a-stem masc/fem/neut (50+ ending rules)
;;   - Verb conjugation: present tense parasmaipada (9 endings)
;;   - 10 lakāras (tenses/moods)
;;   - 10 gaṇas (verb classes)
;;   - 25 common dhātus (verb roots)
;;   - Guṇa and Vṛddhi vowel strengthening
;;   - 6 compound types (samāsa) with resolution rules
;;   - Sentence parsing: kāraka role identification
;;   - Pronouns: tad, asmad, yuṣmad, kim
;;   - 25 indeclinables (avyaya)
;;   - 20 prefixes (upasarga)
;;   - 70+ core vocabulary words
;;
;; THIS IS NOT HISTORY — THESE ARE THE ACTUAL RULES
;; Load this → AI can parse basic Sanskrit
;; ═══════════════════════════════════════════════════════════════════════


;; ═══════════════════════════════════════════════════════════════════════
;; BRIDGE RULES — connect linguistic patterns to observation predicates
;; ═══════════════════════════════════════════════════════════════════════

;; Pattern repetition = mantra (repetitive chanting)
(sanskrit-insight mantra-pattern) if (detected-reflect-h) <0.88, 0.85>
(sanskrit-insight mantra-pattern) if (detected-reflect-v) <0.88, 0.85>

;; Sandhi = transformation at boundaries
(sanskrit-insight sandhi-transform $from $to) if (consistent-remap $from $to) <0.88, 0.85>

;; Compound formation = objects combining
(sanskrit-insight samasa-compound) if (objects-removed $in $out) (obs-consistent output-smaller) <0.85, 0.80>

;; Vibhakti (case declension) = systematic transformation
(sanskrit-insight vibhakti-transform) if (has-geometric-transform) <0.85, 0.80>

;; ─── UNIVERSAL RULES — fire on ANY data ────────────

;; Padārtha — categorization (Nyāya logic)
(sanskrit-insight padartha $x $category) if (is-a $x $category) <0.88, 0.85>
;; Artha — meaning extraction
(sanskrit-insight artha $key) if (meaning $key $val) <0.88, 0.85>
;; Vākya — user utterance intent
(sanskrit-insight vakya-intent $type) if (intent $type) <0.85, 0.80>
;; Āvṛtti — repetition/frequency
(sanskrit-insight avrtti $pattern $count) if (pattern-rate $pattern $count $total) <0.85, 0.80>
;; Sambandha — relationship/connection
(sanskrit-insight sambandha $a $b) if (co-occur $a $b $both $base) <0.85, 0.80>
;; Guṇa — property/quality
(sanskrit-insight guna $x $prop) if (has $x $prop) <0.85, 0.80>
