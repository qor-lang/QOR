;; ═══════════════════════════════════════════════════════════════════════
;; SANSKRIT GRAMMAR RULES — sanskrit_grammar.qor
;; ═══════════════════════════════════════════════════════════════════════
;; ACTUAL EXECUTABLE RULES — not history
;; Based on Pāṇini's Aṣṭādhyāyī
;; AI loads these → can parse and understand Sanskrit
;; ═══════════════════════════════════════════════════════════════════════


;; ─── 1. PHONEME CLASSIFICATION (Māheśvara Sūtras) ──────────────────
;; These 14 sūtras define ALL sounds of Sanskrit.
;; The IT markers (underlined) allow referencing groups.

;; Vowels (ac = a to c marker)
(phoneme a vowel short) <0.99, 0.99>
(phoneme ā vowel long) <0.99, 0.99>
(phoneme i vowel short) <0.99, 0.99>
(phoneme ī vowel long) <0.99, 0.99>
(phoneme u vowel short) <0.99, 0.99>
(phoneme ū vowel long) <0.99, 0.99>
(phoneme ṛ vowel short) <0.99, 0.99>
(phoneme ṝ vowel long) <0.99, 0.99>
(phoneme ḷ vowel short) <0.99, 0.99>
(phoneme e vowel long) <0.99, 0.99>
(phoneme o vowel long) <0.99, 0.99>
(phoneme ai vowel long) <0.99, 0.99>
(phoneme au vowel long) <0.99, 0.99>

;; Vowel pairs (savarna = same class)
(savarna a ā) <0.99, 0.99>
(savarna i ī) <0.99, 0.99>
(savarna u ū) <0.99, 0.99>
(savarna ṛ ṝ) <0.99, 0.99>

;; Vowel weights for prosody (Piṅgala/Chandas)
(rule laghu-vowel
  (phoneme $v vowel short)
  →
  (syllable-weight $v laghu) <0.99, 0.99>
)

(rule guru-vowel
  (phoneme $v vowel long)
  →
  (syllable-weight $v guru) <0.99, 0.99>
)

;; Consonants by place of articulation (sthāna)
;; kaṇṭhya (guttural/velar)
(phoneme ka consonant sparśa kaṇṭhya aghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme kha consonant sparśa kaṇṭhya aghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ga consonant sparśa kaṇṭhya ghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme gha consonant sparśa kaṇṭhya ghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ṅa consonant sparśa kaṇṭhya ghoṣa nāsikya) <0.99, 0.99>

;; tālavya (palatal)
(phoneme ca consonant sparśa tālavya aghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme cha consonant sparśa tālavya aghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ja consonant sparśa tālavya ghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme jha consonant sparśa tālavya ghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ña consonant sparśa tālavya ghoṣa nāsikya) <0.99, 0.99>

;; mūrdhanya (retroflex/cerebral)
(phoneme ṭa consonant sparśa mūrdhanya aghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme ṭha consonant sparśa mūrdhanya aghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ḍa consonant sparśa mūrdhanya ghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme ḍha consonant sparśa mūrdhanya ghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ṇa consonant sparśa mūrdhanya ghoṣa nāsikya) <0.99, 0.99>

;; dantya (dental)
(phoneme ta consonant sparśa dantya aghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme tha consonant sparśa dantya aghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme da consonant sparśa dantya ghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme dha consonant sparśa dantya ghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme na consonant sparśa dantya ghoṣa nāsikya) <0.99, 0.99>

;; oṣṭhya (labial)
(phoneme pa consonant sparśa oṣṭhya aghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme pha consonant sparśa oṣṭhya aghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ba consonant sparśa oṣṭhya ghoṣa alpaprāṇa) <0.99, 0.99>
(phoneme bha consonant sparśa oṣṭhya ghoṣa mahāprāṇa) <0.99, 0.99>
(phoneme ma consonant sparśa oṣṭhya ghoṣa nāsikya) <0.99, 0.99>

;; Semi-vowels (antastha)
(phoneme ya consonant antastha tālavya) <0.99, 0.99>
(phoneme ra consonant antastha mūrdhanya) <0.99, 0.99>
(phoneme la consonant antastha dantya) <0.99, 0.99>
(phoneme va consonant antastha oṣṭhya) <0.99, 0.99>

;; Sibilants (ūṣman)
(phoneme śa consonant ūṣman tālavya aghoṣa) <0.99, 0.99>
(phoneme ṣa consonant ūṣman mūrdhanya aghoṣa) <0.99, 0.99>
(phoneme sa consonant ūṣman dantya aghoṣa) <0.99, 0.99>
(phoneme ha consonant ūṣman kaṇṭhya ghoṣa) <0.99, 0.99>

;; Visarga and Anusvāra
(phoneme ḥ visarga) <0.99, 0.99>
(phoneme ṃ anusvāra) <0.99, 0.99>


;; ─── 2. VOWEL SANDHI RULES (ac-sandhi) ─────────────────────────────
;; When words join, vowels at boundaries change.
;; These are the ACTUAL transformation rules.

;; RULE: a/ā + a/ā → ā (Pāṇini 6.1.101: akaḥ savarṇe dīrghaḥ)
(rule sandhi-a-a (vowel-end $w1 a) (vowel-start $w2 a) → (join $w1 $w2 ā)) <0.99, 0.99>
(rule sandhi-a-aa (vowel-end $w1 a) (vowel-start $w2 ā) → (join $w1 $w2 ā)) <0.99, 0.99>
(rule sandhi-aa-a (vowel-end $w1 ā) (vowel-start $w2 a) → (join $w1 $w2 ā)) <0.99, 0.99>
(rule sandhi-aa-aa (vowel-end $w1 ā) (vowel-start $w2 ā) → (join $w1 $w2 ā)) <0.99, 0.99>

;; RULE: i/ī + i/ī → ī
(rule sandhi-i-i (vowel-end $w1 i) (vowel-start $w2 i) → (join $w1 $w2 ī)) <0.99, 0.99>
(rule sandhi-i-ii (vowel-end $w1 i) (vowel-start $w2 ī) → (join $w1 $w2 ī)) <0.99, 0.99>
(rule sandhi-ii-i (vowel-end $w1 ī) (vowel-start $w2 i) → (join $w1 $w2 ī)) <0.99, 0.99>
(rule sandhi-ii-ii (vowel-end $w1 ī) (vowel-start $w2 ī) → (join $w1 $w2 ī)) <0.99, 0.99>

;; RULE: u/ū + u/ū → ū
(rule sandhi-u-u (vowel-end $w1 u) (vowel-start $w2 u) → (join $w1 $w2 ū)) <0.99, 0.99>
(rule sandhi-u-uu (vowel-end $w1 u) (vowel-start $w2 ū) → (join $w1 $w2 ū)) <0.99, 0.99>
(rule sandhi-uu-u (vowel-end $w1 ū) (vowel-start $w2 u) → (join $w1 $w2 ū)) <0.99, 0.99>
(rule sandhi-uu-uu (vowel-end $w1 ū) (vowel-start $w2 ū) → (join $w1 $w2 ū)) <0.99, 0.99>

;; RULE: a/ā + i/ī → e (Pāṇini 6.1.87: ādguṇaḥ)
(rule sandhi-a-i (vowel-end $w1 a) (vowel-start $w2 i) → (join $w1 $w2 e)) <0.99, 0.99>
(rule sandhi-a-ii (vowel-end $w1 a) (vowel-start $w2 ī) → (join $w1 $w2 e)) <0.99, 0.99>
(rule sandhi-aa-i (vowel-end $w1 ā) (vowel-start $w2 i) → (join $w1 $w2 e)) <0.99, 0.99>
(rule sandhi-aa-ii (vowel-end $w1 ā) (vowel-start $w2 ī) → (join $w1 $w2 e)) <0.99, 0.99>

;; RULE: a/ā + u/ū → o
(rule sandhi-a-u (vowel-end $w1 a) (vowel-start $w2 u) → (join $w1 $w2 o)) <0.99, 0.99>
(rule sandhi-a-uu (vowel-end $w1 a) (vowel-start $w2 ū) → (join $w1 $w2 o)) <0.99, 0.99>
(rule sandhi-aa-u (vowel-end $w1 ā) (vowel-start $w2 u) → (join $w1 $w2 o)) <0.99, 0.99>
(rule sandhi-aa-uu (vowel-end $w1 ā) (vowel-start $w2 ū) → (join $w1 $w2 o)) <0.99, 0.99>

;; RULE: a/ā + ṛ → ar
(rule sandhi-a-ri (vowel-end $w1 a) (vowel-start $w2 ṛ) → (join $w1 $w2 ar)) <0.99, 0.99>
(rule sandhi-aa-ri (vowel-end $w1 ā) (vowel-start $w2 ṛ) → (join $w1 $w2 ar)) <0.99, 0.99>

;; RULE: a/ā + e/ai → ai (Pāṇini 6.1.88: vṛddhireci)
(rule sandhi-a-e (vowel-end $w1 a) (vowel-start $w2 e) → (join $w1 $w2 ai)) <0.99, 0.99>
(rule sandhi-a-ai (vowel-end $w1 a) (vowel-start $w2 ai) → (join $w1 $w2 ai)) <0.99, 0.99>
(rule sandhi-aa-e (vowel-end $w1 ā) (vowel-start $w2 e) → (join $w1 $w2 ai)) <0.99, 0.99>

;; RULE: a/ā + o/au → au
(rule sandhi-a-o (vowel-end $w1 a) (vowel-start $w2 o) → (join $w1 $w2 au)) <0.99, 0.99>
(rule sandhi-a-au (vowel-end $w1 a) (vowel-start $w2 au) → (join $w1 $w2 au)) <0.99, 0.99>
(rule sandhi-aa-o (vowel-end $w1 ā) (vowel-start $w2 o) → (join $w1 $w2 au)) <0.99, 0.99>

;; RULE: i/ī + dissimilar vowel → y + vowel (Pāṇini 6.1.77: iko yaṇaci)
(rule sandhi-i-other (vowel-end $w1 i) (vowel-start $w2 $v) (not-savarna i $v) → (join $w1 $w2 y $v)) <0.99, 0.99>
(rule sandhi-ii-other (vowel-end $w1 ī) (vowel-start $w2 $v) (not-savarna i $v) → (join $w1 $w2 y $v)) <0.99, 0.99>

;; RULE: u/ū + dissimilar vowel → v + vowel
(rule sandhi-u-other (vowel-end $w1 u) (vowel-start $w2 $v) (not-savarna u $v) → (join $w1 $w2 v $v)) <0.99, 0.99>
(rule sandhi-uu-other (vowel-end $w1 ū) (vowel-start $w2 $v) (not-savarna u $v) → (join $w1 $w2 v $v)) <0.99, 0.99>

;; RULE: ṛ + dissimilar vowel → r + vowel
(rule sandhi-ri-other (vowel-end $w1 ṛ) (vowel-start $w2 $v) (not-savarna ṛ $v) → (join $w1 $w2 r $v)) <0.99, 0.99>

;; RULE: e + a → e ' (pragṛhya, elision of a)
(rule sandhi-e-a (vowel-end $w1 e) (vowel-start $w2 a) → (join $w1 $w2 e avagraha)) <0.99, 0.99>

;; RULE: o + a → o ' (elision of a with avagraha)
(rule sandhi-o-a (vowel-end $w1 o) (vowel-start $w2 a) → (join $w1 $w2 o avagraha)) <0.99, 0.99>


;; ─── 3. CONSONANT SANDHI RULES (hal-sandhi) ────────────────────────

;; RULE: Final voiceless stop before voiced → becomes voiced
;; ka→ga, ca→ja, ṭa→ḍa, ta→da, pa→ba (before voiced consonant or vowel)
(rule sandhi-voice-assimilation
  (consonant-end $w1 $c aghoṣa)
  (consonant-start $w2 $c2 ghoṣa)
  (same-sthana $c $voiced)
  (phoneme $voiced consonant sparśa $sthana ghoṣa alpaprāṇa)
  →
  (transform-final $w1 $voiced) <0.99, 0.99>
)

;; Voicing pairs (aghoṣa → ghoṣa of same sthāna)
(voice-pair ka ga) <0.99, 0.99>
(voice-pair kha gha) <0.99, 0.99>
(voice-pair ca ja) <0.99, 0.99>
(voice-pair cha jha) <0.99, 0.99>
(voice-pair ṭa ḍa) <0.99, 0.99>
(voice-pair ṭha ḍha) <0.99, 0.99>
(voice-pair ta da) <0.99, 0.99>
(voice-pair tha dha) <0.99, 0.99>
(voice-pair pa ba) <0.99, 0.99>
(voice-pair pha bha) <0.99, 0.99>

;; RULE: stop before nasal → nasal of same class
;; k before n → ṅ, c before n → ñ, etc.
(nasal-of kaṇṭhya ṅa) <0.99, 0.99>
(nasal-of tālavya ña) <0.99, 0.99>
(nasal-of mūrdhanya ṇa) <0.99, 0.99>
(nasal-of dantya na) <0.99, 0.99>
(nasal-of oṣṭhya ma) <0.99, 0.99>

(rule sandhi-stop-to-nasal
  (consonant-end $w1 $c sparśa $sthana)
  (consonant-start $w2 $nasal ghoṣa nāsikya)
  (nasal-of $sthana $class-nasal)
  →
  (transform-final $w1 $class-nasal) <0.99, 0.99>
)

;; RULE: final t + ś → cch
(rule sandhi-t-sh (consonant-end $w1 ta) (consonant-start $w2 śa) → (transform-final $w1 c) (transform-initial $w2 cha)) <0.99, 0.99>

;; RULE: final t + c/ch → cc/cch
(rule sandhi-t-c (consonant-end $w1 ta) (consonant-start $w2 ca) → (transform-final $w1 ca)) <0.99, 0.99>

;; RULE: final t + j/jh → jj/jjh
(rule sandhi-t-j (consonant-end $w1 ta) (consonant-start $w2 ja) → (transform-final $w1 ja)) <0.99, 0.99>

;; RULE: final t + ṭ → ṭṭ
(rule sandhi-t-retro (consonant-end $w1 ta) (consonant-start $w2 ṭa) → (transform-final $w1 ṭa)) <0.99, 0.99>

;; RULE: final t + l → ll
(rule sandhi-t-l (consonant-end $w1 ta) (consonant-start $w2 la) → (transform-final $w1 la)) <0.99, 0.99>

;; RULE: final t + h → ddh
(rule sandhi-t-h (consonant-end $w1 ta) (consonant-start $w2 ha) → (transform-final $w1 da) (transform-initial $w2 dha)) <0.99, 0.99>

;; RULE: final n + consonant of different class → anusvāra
(rule sandhi-final-n-anusvara
  (consonant-end $w1 na)
  (consonant-start $w2 $c)
  →
  (transform-final $w1 ṃ) <0.90, 0.90>
)


;; ─── 4. VISARGA SANDHI ──────────────────────────────────────────────

;; RULE: aḥ + voiced consonant → o
(rule sandhi-ah-voiced
  (visarga-end $w1 aḥ)
  (consonant-start $w2 $c ghoṣa)
  →
  (transform-final $w1 o) <0.99, 0.99>
)

;; RULE: aḥ + a → o '
(rule sandhi-ah-a
  (visarga-end $w1 aḥ)
  (vowel-start $w2 a)
  →
  (transform-final $w1 o) (elide-initial $w2) <0.99, 0.99>
)

;; RULE: āḥ + voiced → ā
(rule sandhi-aah-voiced
  (visarga-end $w1 āḥ)
  (consonant-start $w2 $c ghoṣa)
  →
  (transform-final $w1 ā) <0.99, 0.99>
)

;; RULE: ḥ + ka/kha → ḥka/ḥkha (no change before k/kh)
(rule sandhi-visarga-ka
  (visarga-end $w1 $vḥ)
  (consonant-start $w2 ka)
  →
  (no-change $w1 $w2) <0.99, 0.99>
)

;; RULE: ḥ + pa/pha → ḥpa/ḥpha (no change before p/ph)
(rule sandhi-visarga-pa
  (visarga-end $w1 $vḥ)
  (consonant-start $w2 pa)
  →
  (no-change $w1 $w2) <0.99, 0.99>
)

;; RULE: ḥ + śa → śśa or ḥśa
(rule sandhi-visarga-sha
  (visarga-end $w1 $vḥ)
  (consonant-start $w2 śa)
  →
  (transform-final $w1 ś) <0.90, 0.90>
)

;; RULE: ḥ + ṣa → ṣṣa
(rule sandhi-visarga-retro-sha
  (visarga-end $w1 $vḥ)
  (consonant-start $w2 ṣa)
  →
  (transform-final $w1 ṣ) <0.90, 0.90>
)

;; RULE: ḥ + sa → ssa
(rule sandhi-visarga-sa
  (visarga-end $w1 $vḥ)
  (consonant-start $w2 sa)
  →
  (transform-final $w1 s) <0.90, 0.90>
)


;; ─── 5. NOUN DECLENSION (Vibhakti) ─────────────────────────────────
;; 8 cases × 3 numbers × 3 genders = 72 forms per stem
;; Below: a-stem masculine (most common pattern, like deva/rāma)

;; Case names and their meanings (kāraka relations)
(vibhakti 1 prathamā nominative kartā agent "who/what does") <0.99, 0.99>
(vibhakti 2 dvitīyā accusative karma object "whom/what") <0.99, 0.99>
(vibhakti 3 tṛtīyā instrumental karaṇa instrument "by/with") <0.99, 0.99>
(vibhakti 4 caturthī dative sampradāna recipient "for/to") <0.99, 0.99>
(vibhakti 5 pañcamī ablative apādāna source "from") <0.99, 0.99>
(vibhakti 6 ṣaṣṭhī genitive sambandha relation "of/possessive") <0.99, 0.99>
(vibhakti 7 saptamī locative adhikaraṇa location "in/on/at") <0.99, 0.99>
(vibhakti 8 sambodhana vocative āmantrita address "O!/hey") <0.99, 0.99>

;; a-stem masculine endings (deva = god)
;; singular (ekavacana)
(rule decline-a-m-1-sg (stem $w a masculine) (case prathamā) (number sg) → (form $w aḥ)) <0.99, 0.99>
(rule decline-a-m-2-sg (stem $w a masculine) (case dvitīyā) (number sg) → (form $w am)) <0.99, 0.99>
(rule decline-a-m-3-sg (stem $w a masculine) (case tṛtīyā) (number sg) → (form $w ena)) <0.99, 0.99>
(rule decline-a-m-4-sg (stem $w a masculine) (case caturthī) (number sg) → (form $w āya)) <0.99, 0.99>
(rule decline-a-m-5-sg (stem $w a masculine) (case pañcamī) (number sg) → (form $w āt)) <0.99, 0.99>
(rule decline-a-m-6-sg (stem $w a masculine) (case ṣaṣṭhī) (number sg) → (form $w asya)) <0.99, 0.99>
(rule decline-a-m-7-sg (stem $w a masculine) (case saptamī) (number sg) → (form $w e)) <0.99, 0.99>
(rule decline-a-m-8-sg (stem $w a masculine) (case sambodhana) (number sg) → (form $w a)) <0.99, 0.99>

;; dual (dvivacana)
(rule decline-a-m-1-du (stem $w a masculine) (case prathamā) (number du) → (form $w au)) <0.99, 0.99>
(rule decline-a-m-2-du (stem $w a masculine) (case dvitīyā) (number du) → (form $w au)) <0.99, 0.99>
(rule decline-a-m-3-du (stem $w a masculine) (case tṛtīyā) (number du) → (form $w ābhyām)) <0.99, 0.99>
(rule decline-a-m-4-du (stem $w a masculine) (case caturthī) (number du) → (form $w ābhyām)) <0.99, 0.99>
(rule decline-a-m-5-du (stem $w a masculine) (case pañcamī) (number du) → (form $w ābhyām)) <0.99, 0.99>
(rule decline-a-m-6-du (stem $w a masculine) (case ṣaṣṭhī) (number du) → (form $w ayoḥ)) <0.99, 0.99>
(rule decline-a-m-7-du (stem $w a masculine) (case saptamī) (number du) → (form $w ayoḥ)) <0.99, 0.99>

;; plural (bahuvacana)
(rule decline-a-m-1-pl (stem $w a masculine) (case prathamā) (number pl) → (form $w āḥ)) <0.99, 0.99>
(rule decline-a-m-2-pl (stem $w a masculine) (case dvitīyā) (number pl) → (form $w ān)) <0.99, 0.99>
(rule decline-a-m-3-pl (stem $w a masculine) (case tṛtīyā) (number pl) → (form $w aiḥ)) <0.99, 0.99>
(rule decline-a-m-4-pl (stem $w a masculine) (case caturthī) (number pl) → (form $w ebhyaḥ)) <0.99, 0.99>
(rule decline-a-m-5-pl (stem $w a masculine) (case pañcamī) (number pl) → (form $w ebhyaḥ)) <0.99, 0.99>
(rule decline-a-m-6-pl (stem $w a masculine) (case ṣaṣṭhī) (number pl) → (form $w ānām)) <0.99, 0.99>
(rule decline-a-m-7-pl (stem $w a masculine) (case saptamī) (number pl) → (form $w eṣu)) <0.99, 0.99>

;; ā-stem feminine endings (vidyā = knowledge)
(rule decline-aa-f-1-sg (stem $w ā feminine) (case prathamā) (number sg) → (form $w ā)) <0.99, 0.99>
(rule decline-aa-f-2-sg (stem $w ā feminine) (case dvitīyā) (number sg) → (form $w ām)) <0.99, 0.99>
(rule decline-aa-f-3-sg (stem $w ā feminine) (case tṛtīyā) (number sg) → (form $w ayā)) <0.99, 0.99>
(rule decline-aa-f-4-sg (stem $w ā feminine) (case caturthī) (number sg) → (form $w āyai)) <0.99, 0.99>
(rule decline-aa-f-5-sg (stem $w ā feminine) (case pañcamī) (number sg) → (form $w āyāḥ)) <0.99, 0.99>
(rule decline-aa-f-6-sg (stem $w ā feminine) (case ṣaṣṭhī) (number sg) → (form $w āyāḥ)) <0.99, 0.99>
(rule decline-aa-f-7-sg (stem $w ā feminine) (case saptamī) (number sg) → (form $w āyām)) <0.99, 0.99>
(rule decline-aa-f-1-pl (stem $w ā feminine) (case prathamā) (number pl) → (form $w āḥ)) <0.99, 0.99>
(rule decline-aa-f-2-pl (stem $w ā feminine) (case dvitīyā) (number pl) → (form $w āḥ)) <0.99, 0.99>
(rule decline-aa-f-6-pl (stem $w ā feminine) (case ṣaṣṭhī) (number pl) → (form $w ānām)) <0.99, 0.99>

;; a-stem neuter endings (phala = fruit)
(rule decline-a-n-1-sg (stem $w a neuter) (case prathamā) (number sg) → (form $w am)) <0.99, 0.99>
(rule decline-a-n-2-sg (stem $w a neuter) (case dvitīyā) (number sg) → (form $w am)) <0.99, 0.99>
(rule decline-a-n-1-du (stem $w a neuter) (case prathamā) (number du) → (form $w e)) <0.99, 0.99>
(rule decline-a-n-1-pl (stem $w a neuter) (case prathamā) (number pl) → (form $w āni)) <0.99, 0.99>
(rule decline-a-n-2-pl (stem $w a neuter) (case dvitīyā) (number pl) → (form $w āni)) <0.99, 0.99>
;; Cases 3-7 same as masculine for a-stem neuter


;; ─── 6. VERB CONJUGATION (Dhātu + Lakāra) ──────────────────────────
;; 10 tenses/moods (lakāra) × 3 persons × 3 numbers = 90 forms per root

;; Person/number endings for present tense (laṭ-lakāra, parasmaipada)
(rule conjugate-lat-p3-sg (dhātu $root $gana) (lakāra laṭ) (puruṣa prathama) (number sg) → (ending ti)) <0.99, 0.99>
(rule conjugate-lat-p3-du (dhātu $root $gana) (lakāra laṭ) (puruṣa prathama) (number du) → (ending taḥ)) <0.99, 0.99>
(rule conjugate-lat-p3-pl (dhātu $root $gana) (lakāra laṭ) (puruṣa prathama) (number pl) → (ending anti)) <0.99, 0.99>

(rule conjugate-lat-p2-sg (dhātu $root $gana) (lakāra laṭ) (puruṣa madhyama) (number sg) → (ending si)) <0.99, 0.99>
(rule conjugate-lat-p2-du (dhātu $root $gana) (lakāra laṭ) (puruṣa madhyama) (number du) → (ending thaḥ)) <0.99, 0.99>
(rule conjugate-lat-p2-pl (dhātu $root $gana) (lakāra laṭ) (puruṣa madhyama) (number pl) → (ending tha)) <0.99, 0.99>

(rule conjugate-lat-p1-sg (dhātu $root $gana) (lakāra laṭ) (puruṣa uttama) (number sg) → (ending mi)) <0.99, 0.99>
(rule conjugate-lat-p1-du (dhātu $root $gana) (lakāra laṭ) (puruṣa uttama) (number du) → (ending vaḥ)) <0.99, 0.99>
(rule conjugate-lat-p1-pl (dhātu $root $gana) (lakāra laṭ) (puruṣa uttama) (number pl) → (ending maḥ)) <0.99, 0.99>

;; 10 Lakāras (tenses/moods)
(lakāra laṭ present "he does / is doing") <0.99, 0.99>
(lakāra liṭ perfect "he did (remote past)") <0.99, 0.99>
(lakāra luṭ periphrastic-future "he will do (distant future)") <0.99, 0.99>
(lakāra lṛṭ simple-future "he will do") <0.99, 0.99>
(lakāra leṭ subjunctive "that he may do (Vedic)") <0.99, 0.99>
(lakāra loṭ imperative "let him do / do!") <0.99, 0.99>
(lakāra laṅ imperfect "he was doing") <0.99, 0.99>
(lakāra liṅ optative-potential "he should do / would do") <0.99, 0.99>
(lakāra luṅ aorist "he did (recent past)") <0.99, 0.99>
(lakāra lṛṅ conditional "he would have done") <0.99, 0.99>

;; 10 verb classes (gaṇa)
(gaṇa 1 bhvādi "bhū class — guṇa of root vowel + a") <0.99, 0.99>
(gaṇa 2 adādi "ad class — no vikaraṇa, root used directly") <0.99, 0.99>
(gaṇa 3 juhotyādi "hu class — reduplication of root") <0.99, 0.99>
(gaṇa 4 divādi "div class — ya added to root") <0.99, 0.99>
(gaṇa 5 svādi "su class — nu/no added to root") <0.99, 0.99>
(gaṇa 6 tudādi "tud class — a added to root (no guṇa)") <0.99, 0.99>
(gaṇa 7 rudhādi "rudh class — na/n infixed in root") <0.99, 0.99>
(gaṇa 8 tanādi "tan class — u/o added to root") <0.99, 0.99>
(gaṇa 9 kryādi "krī class — nā/nī added to root") <0.99, 0.99>
(gaṇa 10 curādi "cur class — aya added to root (causative-like)") <0.99, 0.99>

;; Common verb roots (dhātu)
(dhātu bhū 1 parasmai "to be, to become") <0.99, 0.99>
(dhātu gam 1 parasmai "to go") <0.99, 0.99>
(dhātu paṭh 1 parasmai "to read, to recite") <0.99, 0.99>
