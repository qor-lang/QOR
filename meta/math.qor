;; ═══════════════════════════════════════════════════════════════════════
;; ACTIVE REASONING RULES — match on observations, produce math insights
;; ═══════════════════════════════════════════════════════════════════════

;; Symmetry group detection
(math-insight symmetry-reflection) if (detected-reflect-h) <0.95, 0.90>
(math-insight symmetry-reflection) if (detected-reflect-v) <0.95, 0.90>
(math-insight rotational-symmetry) if (detected-rotate-180) <0.95, 0.90>
(math-insight rotational-symmetry) if (detected-rotate-90) <0.95, 0.90>

;; Set operations on cells
(math-insight set-subtraction) if (selective-removal $in $out) <0.90, 0.85>
(math-insight set-intersection) if (objects-preserved $in $out) (objects-removed $in $out) <0.90, 0.85>

;; Invariant detection
(math-insight size-invariant) if (obs-consistent same-size) <0.92, 0.90>
(math-insight bijection) if (consistent-remap $from $to) not (conflicting-remap $from) <0.88, 0.85>

;; Scaling = multiplication
(math-insight multiplicative-scaling $f) if (detected-scale-up $f) <0.95, 0.90>

;; Translation = group action
(math-insight translation-vector $dr $dc) if (detected-shift $dr $dc) <0.93, 0.90>

;; ─── UNIVERSAL RULES — fire on ANY data, not just puzzles ────────────

;; Statistical patterns from learning pipeline
(math-insight frequency $pattern $count) if (pattern-rate $pattern $count $total) <0.90, 0.85>
(math-insight correlation $a $b) if (co-occur $a $b $both $base) <0.88, 0.85>
(math-insight boundary $indicator $value) if (threshold $indicator $pattern $value) <0.90, 0.88>
(math-insight measured $name) if (indicator $name $desc) <0.85, 0.80>

;; Knowledge structure — set membership, mapping
(math-insight set-membership $x $set) if (is-a $x $set) <0.90, 0.85>
(math-insight property-map $x $prop) if (has $x $prop) <0.88, 0.85>
(math-insight capability $x $ability) if (can $x $ability) <0.85, 0.80>

;; Semantic structure
(math-insight domain-identified $d) if (domain $d) <0.85, 0.80>
(math-insight definition $key) if (meaning $key $val) <0.85, 0.80>

;; Graph structure — edges as relations
(math-insight graph-edge $src $tgt) if (dna-edge $src $rel $tgt) <0.85, 0.80>
