;; Breath ratios (pūraka:kumbhaka:recaka)
(pranayama-ratio beginner 1 1 1) <0.99, 0.99>
(pranayama-ratio intermediate 1 2 2) <0.99, 0.99>
(pranayama-ratio advanced 1 4 2) <0.99, 0.99>

;; Standard counts
(pranayama-matra-unit 0.4 seconds) <0.99, 0.99>     ;; 1 mātrā ≈ 0.4s
(pranayama-puraka 12 matras) <0.99, 0.99>            ;; inhale
(pranayama-kumbhaka 48 matras) <0.99, 0.99>          ;; hold
(pranayama-rechaka 24 matras) <0.99, 0.99>           ;; exhale

;; Daily breath count
(rule pranayama-daily-breaths
  ;; 15 breaths/min × 60 min × 24 hours = 21600
  (mul 15 60 $per-hour) (mul $per-hour 24 $daily)
  → (daily-breaths $daily) <0.99, 0.99>)             ;; = 21600


