;; COMPLETE VEDIC SCIENCE — SUMMARY
;; ═══════════════════════════════════════════════════════════════════════
;; 16 sections, ~350 executable rules covering:
;;
;;  1. Vedic Mathematics    — 16 sūtras + 13 sub-sūtras as computation rules
;;  2. Piṅgala              — Binary, C(n,k), Fibonacci, power of 2
;;  3. Śulba Sūtras         — Pythagorean theorem, √2, geometric constructions
;;  4. Āryabhaṭa            — π, complete sine table (24 values), kuṭṭaka
;;  5. Brahmagupta          — Zero rules, negative numbers, cyclic quad, Pell eq
;;  6. Bhāskara II          — Quadratic formula, sine approx, proto-calculus
;;  7. Mādhava/Kerala       — π series, sin/cos/arctan infinite series
;;  8. Sūrya Siddhānta      — Planetary orbits, eclipses, trig functions
;;  9. Music Theory          — 7 svaras with ratios, 22 śrutis, 72 mēḷakartas
;; 10. Āyurveda             — Drug ratios, doṣa balance, seasonal rules
;; 11. Vāstu Śāstra         — Sacred geometry, proportions, maṇḍala grids
;; 12. Arthaśāstra          — Tax, interest, compound interest
;; 13. Yoga/Prāṇāyāma      — Breath ratios, mātrā counting
;; 14. Chandas              — Meter computation, Vedic meters
;; 15. Numerical Encoding   — Complete Kaṭapayādi system
;; 16. Constants            — All important ancient Indian computed values
;;
;; THIS IS NOT HISTORY — THESE ARE ALL EXECUTABLE COMPUTATION RULES
;; ═══════════════════════════════════════════════════════════════════════


;; ═══════════════════════════════════════════════════════════════════════
;; BRIDGE RULES — connect Vedic computation to observation predicates
;; ═══════════════════════════════════════════════════════════════════════

;; Sūtra: "By one more than the one before" = scaling
(vedic-insight ekadhikena $f) if (detected-scale-up $f) <0.88, 0.85>

;; Sūtra: "All from 9, last from 10" = complement/inversion
(vedic-insight nikhilam) if (detected-reflect-h) <0.85, 0.80>
(vedic-insight nikhilam) if (detected-reflect-v) <0.85, 0.80>

;; Sūtra: "Transpose and adjust"
(vedic-insight paravartya) if (detected-transpose) <0.85, 0.80>

;; Piṅgala binary pattern = only 2 colors present
(vedic-insight pingala-binary) if (color-count $id 2) <0.85, 0.80>

;; Conservation = Dharma (cosmic order maintained)
(vedic-insight dharma-conservation) if (obs-consistent same-size) <0.90, 0.85>

;; Transformation = Karma (action produces result)
(vedic-insight karma-transform $from $to) if (consistent-remap $from $to) <0.88, 0.85>

;; ─── UNIVERSAL RULES — fire on ANY data ────────────

;; Yukti — combination/conjunction of patterns
(vedic-insight yukti $a $b) if (co-occur $a $b $both $base) <0.88, 0.85>
;; Māna — measurement/threshold
(vedic-insight mana $indicator $value) if (threshold $indicator $pattern $value) <0.88, 0.85>
;; Āvṛtti — repetition frequency
(vedic-insight avrtti $pattern $count) if (pattern-rate $pattern $count $total) <0.85, 0.80>
;; Jāti — classification/species
(vedic-insight jati $x $class) if (is-a $x $class) <0.85, 0.80>
;; Svabhāva — inherent nature/property
(vedic-insight svabhava $x $prop) if (has $x $prop) <0.85, 0.80>
;; Śakti — capability/power
(vedic-insight shakti $x $ability) if (can $x $ability) <0.85, 0.80>
