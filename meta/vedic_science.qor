;; SECTION 10: ĀYURVEDA — Computation
;; ═════════════════════════════════════════════════════════════════

;; Drug preparation ratios
(ayurveda-ratio kvatha 1 16 "boil to 1/4") <0.99, 0.99>    ;; decoction
(ayurveda-ratio phanta 1 4 "hot infusion") <0.99, 0.99>     ;; hot infusion
(ayurveda-ratio hima 1 6 "cold infusion") <0.99, 0.99>      ;; cold infusion
(ayurveda-ratio kajjali 1 1 "mercury:sulfur") <0.99, 0.99>  ;; kajjalī

;; Kvātha preparation
(rule ayurveda-kvatha
  (prepare-kvatha $drug-parts)
  (mul $drug-parts 16 $water)           ;; 1:16 ratio
  (div $water 4 $final-volume)           ;; boil to 1/4
  → (kvatha $drug-parts $water $final-volume) <0.99, 0.99>)

;; Seasonal doṣa adjustment
(dosha-season varsha vata increase "reduce dry cold") <0.99, 0.99>
(dosha-season grishma pitta increase "reduce hot spicy") <0.99, 0.99>
(dosha-season shishira kapha increase "reduce heavy oily") <0.99, 0.99>
(dosha-season vasanta kapha decrease "light warm foods") <0.99, 0.99>
(dosha-season sharad pitta decrease "cooling foods") <0.99, 0.99>
(dosha-season hemanta vata decrease "nourishing foods") <0.99, 0.99>


