;; SECTION 12: ARTHAŚĀSTRA — Economics
;; ═════════════════════════════════════════════════════════════════

;; Tax rates (Kauṭilya)
(kautilya-tax agriculture "1/6 of produce") <0.99, 0.99>
(kautilya-profit local 0.05 "5% on local goods") <0.99, 0.99>
(kautilya-profit import 0.10 "10% on imports") <0.99, 0.99>
(kautilya-interest standard 0.0125 "1.25% per month = 15% per year") <0.99, 0.99>
(kautilya-interest commercial 0.05 "5% per month = 60% per year") <0.99, 0.99>

;; Compound interest (known in ancient India)
(rule kautilya-compound-interest
  (compound $principal $rate $periods)
  (add 1 $rate $base) (power $base $periods $factor)
  (mul $principal $factor $amount)
  → (final-amount $amount) <0.99, 0.99>)


