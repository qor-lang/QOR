;; ═══════════════════════════════════════════════════════════════════════
;; ACTIVE REASONING RULES — match on observations, produce physics insights
;; ═══════════════════════════════════════════════════════════════════════

;; Conservation laws
(physics-insight conservation-of-matter) if (obs-consistent same-size) (objects-preserved $in $out) <0.93, 0.90>
(physics-insight matter-creation) if (obs-consistent output-larger) <0.90, 0.85>
(physics-insight matter-annihilation) if (obs-consistent output-smaller) <0.90, 0.85>

;; Motion detection
(physics-insight displacement $dr $dc) if (detected-shift $dr $dc) <0.95, 0.90>
(physics-insight rotation-motion) if (detected-rotate-90) <0.93, 0.90>
(physics-insight reflection-symmetry) if (detected-reflect-h) <0.93, 0.90>
(physics-insight reflection-symmetry) if (detected-reflect-v) <0.93, 0.90>

;; Force-like interactions
(physics-insight selective-force) if (selective-removal $in $out) <0.88, 0.85>
(physics-insight catalyst-interaction) if (marker-driven $in $out) <0.90, 0.85>

;; Phase transition (color change = state change)
(physics-insight phase-transition $from $to) if (consistent-remap $from $to) <0.90, 0.88>

;; ─── UNIVERSAL RULES — fire on ANY data, not just puzzles ────────────

;; Oscillation frequency from learning
(physics-insight oscillation-frequency $pattern $count) if (pattern-rate $pattern $count $total) <0.88, 0.85>
;; Coupled systems — things that co-occur are coupled
(physics-insight coupled-system $a $b) if (co-occur $a $b $both $base) <0.90, 0.85>
;; Phase boundary — threshold = critical point
(physics-insight critical-point $indicator $value) if (threshold $indicator $pattern $value) <0.90, 0.88>
;; Observable quantity
(physics-insight observable $name) if (indicator $name $desc) <0.85, 0.80>

;; Causal structure from knowledge
(physics-insight causal-relation $cause $effect) if (dna-edge $cause causes $effect) <0.90, 0.85>
(physics-insight system-property $system $prop) if (has $system $prop) <0.88, 0.85>
(physics-insight classification $entity $type) if (is-a $entity $type) <0.85, 0.80>

;; Domain awareness
(physics-insight field-detected $d) if (domain $d) <0.85, 0.80>
