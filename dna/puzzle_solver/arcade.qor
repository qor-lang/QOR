(trial-seq sp80 0 f 4 right) <0.95, 0.95>
(trial-seq sp80 0 f 5 right) <0.95, 0.95>
(trial-seq sp80 0 f 6 space) <0.95, 0.95>
;; Variation g: down×2, right×3, space
(trial-seq sp80 0 g 1 down) <0.95, 0.95>
