(trial-seq as66 3 c 9 up) <0.95, 0.95>
(trial-seq as66 3 c 10 up) <0.95, 0.95>
(trial-seq as66 3 c 11 left) <0.95, 0.95>
(trial-seq as66 3 c 12 left) <0.95, 0.95>
