(trial-seq as66 3 b 13 left) <0.95, 0.95>
;; Variation c: up×9, up×1, left×5 (9 ups for pink)
(trial-seq as66 3 c 1 up) <0.95, 0.95>
(trial-seq as66 3 c 2 up) <0.95, 0.95>
(trial-seq as66 3 c 3 up) <0.95, 0.95>
