;; ═══════════════════════════════════════════════════════
;; 4. BOARD GAMES (lp* games)
;; ═══════════════════════════════════════════════════════
;; LP85 = Ludo/Parcheesi-style board game. Cross-shaped track.
;; Turn-based: SPACE to roll/confirm, arrows to select piece/direction.
;; Pattern: space → arrow → space (roll → pick → confirm).

;; Board game replay: known sequence for current level
(strategy-select replay-sequence) if (game-type board-game) (current-level $lv) (level-has-sequence $lv) <0.95, 0.95>
;; Board game: use QOR action-select when no sequence known
(strategy-select qor-direct) if (game-type board-game) (current-level $lv) not (level-has-sequence $lv) <0.80, 0.80>

;; Space-heavy pattern: roll/confirm is the primary action
(action-select space) if (game-type board-game) (turn-phase 0) <0.65, 0.65>
(action-select right) if (game-type board-game) (turn-phase 1) not (wall-hit right) <0.55, 0.55>
(action-select space) if (game-type board-game) (turn-phase 2) <0.65, 0.65>
(action-select down) if (game-type board-game) (turn-phase 3) not (wall-hit down) <0.55, 0.55>

;; When stuck, try directions not blocked
(action-select space) if (game-type board-game) (consecutive-no-change $n) (> $n 3) <0.70, 0.70>
(action-select up) if (game-type board-game) (consecutive-no-change $n) (> $n 5) not (wall-hit up) <0.65, 0.65>
(action-select left) if (game-type board-game) (consecutive-no-change $n) (> $n 7) not (wall-hit left) <0.65, 0.65>
(action-select space) if (game-type board-game) (consecutive-no-change $n) (> $n 9) <0.75, 0.75>

;; ═══════════════════════════════════════════════════════
;; 5. GROWTH / DEFLECTOR (sp* games)
;; ═══════════════════════════════════════════════════════
;; SP80 = growth/deflector puzzle. Source block(s) at top emit magenta
;; growth downward. Player moves horizontal bar with arrows to position
;; it as a deflector. Growth hits bar → deflects horizontally → continues
;; down into U-shaped containers at bottom.
;; Pattern: position bar (arrows) → trigger/wait for growth (space/down)
;; Bar: blue=movable, red=locked during growth.

;; Growth replay: known sequence for current level
(strategy-select replay-sequence) if (game-type growth) (current-level $lv) (level-has-sequence $lv) <0.95, 0.95>
;; Growth: use QOR action-select when no sequence known
(strategy-select qor-direct) if (game-type growth) (current-level $lv) not (level-has-sequence $lv) <0.80, 0.80>

;; Phase 1: Position bar horizontally (skip wall-hit dirs)
(action-select left) if (game-type growth) (turn-phase 0) not (wall-hit left) <0.65, 0.65>
(action-select right) if (game-type growth) (turn-phase 1) not (wall-hit right) <0.65, 0.65>
;; Phase 2: Trigger growth or adjust bar vertically
(action-select space) if (game-type growth) (turn-phase 2) <0.60, 0.60>
(action-select down) if (game-type growth) (turn-phase 3) not (wall-hit down) <0.55, 0.55>

;; Wall-hit: if bar hit edge, try opposite
(action-select right) if (game-type growth) (turn-phase 0) (wall-hit left) not (wall-hit right) <0.63, 0.63>
(action-select left) if (game-type growth) (turn-phase 1) (wall-hit right) not (wall-hit left) <0.63, 0.63>

;; After triggering, try new positions (skip blocked dirs)
(action-select up) if (game-type growth) (consecutive-no-change $n) (> $n 3) not (wall-hit up) <0.60, 0.60>
(action-select left) if (game-type growth) (consecutive-no-change $n) (> $n 5) not (wall-hit left) <0.65, 0.65>
(action-select right) if (game-type growth) (consecutive-no-change $n) (> $n 7) not (wall-hit right) <0.65, 0.65>
(action-select space) if (game-type growth) (consecutive-no-change $n) (> $n 9) <0.70, 0.70>

;; ── SP80 Trial Sequences ──
;; All levels: position horizontal bar (arrows) → space to drop from top
;; Pattern: move bar right/left/down → space (trigger drop)
;; Same setup every level — vary the number of horizontal moves

;; ══════════════════════════════════════════
;; SP80 Level 0 — blue bar, 1 source, 2 yellow containers
;; ══════════════════════════════════════════
;; Rule a: down×1, right×3, space (MAIN COMBO)
(trial-seq sp80 0 a 1 down) <0.95, 0.95>
(trial-seq sp80 0 a 2 right) <0.95, 0.95>
(trial-seq sp80 0 a 3 right) <0.95, 0.95>
(trial-seq sp80 0 a 4 right) <0.95, 0.95>
