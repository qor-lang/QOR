;; ═══════════════════════════════════════════════════════
;; 6. UNKNOWN GAMES — EXPLORATION PROTOCOL
;; ═══════════════════════════════════════════════════════
;; Try every action systematically. Space is the safest first action.
;; Increase priority of space when stuck (most games use space to confirm/advance).

(action-select space) if (game-type unknown) (turn-phase 0) <0.40, 0.40>
(action-select right) if (game-type unknown) (turn-phase 1) <0.40, 0.40>
(action-select down) if (game-type unknown) (turn-phase 2) <0.40, 0.40>
(action-select up) if (game-type unknown) (turn-phase 3) <0.40, 0.40>

;; Stuck escalation: try everything
(action-select left) if (game-type unknown) (consecutive-no-change $n) (> $n 4) <0.50, 0.50>
(action-select space) if (game-type unknown) (consecutive-no-change $n) (> $n 8) <0.60, 0.60>

;; ═══════════════════════════════════════════════════════
;; 7. CROSS-GAME META-RULES
;; ═══════════════════════════════════════════════════════
;; These fire regardless of game type for common situations.

;; If many turns with no change, always try space (universal confirm/advance)
(action-select space) if (consecutive-no-change $n) (> $n 15) <0.80, 0.80>

;; Early game: be more exploratory (try different directions)
(action-select right) if (frame-number $f) (< $f 5) <0.35, 0.35>
(action-select down) if (frame-number $f) (< $f 10) (> $f 4) <0.35, 0.35>

;; ═══════════════════════════════════════════════════════
;; 8. COMBO VARIATION — Learn from previous wins
;; ═══════════════════════════════════════════════════════
;; When Rust detects an unsolved level, it injects:
;;   (prev-win-click LEVEL SEQ_IDX COLOR X Y COUNT)
;;   (prev-win-level LEVEL TOTAL_CLICKS)
;;   (prev-fail-count N)
;;   (grid-segment ID COLOR CX CY W H)
;;   (current-level N)
;;   (grid-bg-color C)
;;   (segment-count N)
;;   (vary-ready)                          — trigger signal
;;
;; QOR produces:
;;   (try-sequence ID)                     — a sequence to attempt
;;   (try-click SEQ_ID STEP X Y)           — individual click in sequence
;;   (vary-use-prev-pattern LEVEL)         — tell Rust to map level's pattern

;; A color is "click-worthy" if it was clicked in a previous winning combo
(click-color $c) if (vary-ready) (prev-win-click $lv $seq $c $x $y $cnt) <0.90, 0.90>

;; A segment is a "target" if its color matches a previously-clicked color
(target-seg $id $c $cx $cy) if (vary-ready) (grid-segment $id $c $cx $cy $w $h) (click-color $c) <0.85, 0.85>

;; Strategy A: Click every target segment once (flood-fill order = segment ID)
(try-sequence all-targets) if (vary-ready) (target-seg $id $c $cx $cy) <0.80, 0.80>
(try-click all-targets $id $cx $cy) if (try-sequence all-targets) (target-seg $id $c $cx $cy) <0.80, 0.80>

;; Strategy B: Replicate pattern from each previously solved level
;; QOR decides which level to use as template — Rust does geometric mapping
(vary-use-prev-pattern $lv) if (vary-ready) (prev-win-level $lv $clicks) <0.85, 0.85>
