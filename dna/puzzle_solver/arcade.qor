(trial-seq as66 3 c 14 left) <0.95, 0.95>
(trial-seq as66 3 c 15 left) <0.95, 0.95>
;; Variation d: up×8, up×2, left×5 (2 ups for blue instead of 1)
(trial-seq as66 3 d 1 up) <0.95, 0.95>
